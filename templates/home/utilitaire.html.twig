{% extends 'base.html.twig' %}

{% block title %}Assurance Utilitaire Pro | Fourgon & Camionnette{% endblock %}
{% block og_title %}Assurance Utilitaire Professionnel — Devis en Ligne{% endblock %}
{% block og_description %}Assurance utilitaire professionnelle pour artisans et PME. Garanties vol, contenu pro, assistance 0 km. Devis en ligne rapide.{% endblock %}
{% block description %}<meta name="description" content="Protégez votre utilitaire avec une assurance professionnelle adaptée aux artisans et PME. Garanties vol, contenu pro (outillage, marchandises), assistance 0km. Obtenez votre devis en ligne.
		">
{% endblock %}
{% block body %}
	<h1 class="sr-only">Assurance Utilitaire Professionnel — Fourgon, Camionnette & Van pour Artisans</h1>
	<section
		class="py-0 lg:py-2 bg-gradient-to-br from-light via-surfaceHover to-light relative overflow-hidden">
		<!-- Background decoration -->
		<div class="hidden lg:flex absolute top-2 left-2 lg:top-5 lg:left-5 floating-animation">
			<i class="fas fa-truck-moving text-blue-600 text-2xl lg:text-4xl opacity-30"></i>
		</div>
		<div class="hidden lg:flex absolute bottom-2 right-2 lg:bottom-5 lg:right-5 floating-animation" style="animation-delay: -2s;">
			<i class="fas fa-truck-loading text-blue-700 text-3xl lg:text-5xl opacity-25"></i>
		</div>

		<div class="w-full mx-auto px-4 lg:px-40 relative z-10">
			<div
				class="flex flex-col lg:flex-row gap-2 lg:gap-3 items-stretch">

				<!-- Image Section - 70% -->
				<div class="order-2 lg:order-1 slide-in-left flex-1 lg:flex-[7]">
					<div class="relative h-full min-h-[150px] lg:min-h-[400px]">
						<div class="w-full h-full bg-gradient-to-br from-blue-400 to-blue-500 shadow-2xl overflow-hidden rounded-xl lg:rounded-3xl">
							<img src="{{ asset('images/assurance-utilitaire.jpg') }}" alt="Fourgon utilitaire pour artisan — assurance utilitaire professionnelle Aksam" class="w-full h-full rounded-xl lg:rounded-3xl shadow-2xl" fetchpriority="high"/>
						</div>
					</div>
				</div>

				<!-- Form Section - 30% -->
				<div class="order-1 lg:order-2 slide-in-right flex-1 lg:flex-[3]">
				    <div class="bg-surface rounded-xl lg:rounded-3xl shadow-2xl p-4 lg:p-6 card-hover border border-gray-100 h-full">
					 	<div
							class="text-center mb-4 lg:mb-12">
							<div class="w-10 h-10 lg:w-12 lg:h-12 rounded-xl mx-auto mb-2 flex items-center justify-center">
								 
								  <i class="fas fa-calculator text-lg lg:text-2xl text-accent"></i>
							 </div>
							<h2 class="text-sm lg:text-xl font-bold text-gradient mb-2 leading-tight">Demandez votre devis utilitaire</h2>
							{# <div class="w-12 h-1 bg-gradient-to-r from-blue-400 to-blue-500 mx-auto rounded-full"></div> #}
						</div>


						<!-- Nom -->
						{{ form_start(form, {'attr': {'id': 'contactForm', 'class': 'space-y-2 lg:space-y-3'}}) }}

						
						<!-- Raison sociale -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-building text-accent text-sm"></i>
								</span>
								{{ form_widget(form.raison) }}
							</div>
							{{ form_errors(form.raison) }}
						</div>

						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-briefcase text-accentchamp text-sm"></i>
								</span>
								<select id="transport_type" name="type" required="required" class="flex-1 px-3 py-2 border border-gray-200 rounded-r-lg bg-light focus:bg-surface transition-all duration-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" style="appearance: auto; -webkit-appearance: menulist;">
								<option value="" selected="selected">Demarage d'activité </option>
								<option value="">OUI</option>
								<option value="">NON</option>
								</select>
							</div>
							
						</div>
						
						<!-- Activité -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-briefcase text-accent text-sm"></i>
								</span>
								{{ form_widget(form.activite) }}
							</div>
							{{ form_errors(form.activite) }}
						</div>

						<!-- Véhicule assuré -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-shield-alt text-accent text-sm"></i>
								</span>
								{{ form_widget(form.assurer) }}
							</div>
							{{ form_errors(form.assurer) }}
						</div>

						<!-- Code Postal -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-map-marker-alt text-accent text-sm"></i>
								</span>
								{{ form_widget(form.codePostale) }}
							</div>
							{{ form_errors(form.codePostale) }}
						</div>

						<!-- Nom -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-user text-accent text-sm"></i>
								</span>
								{{ form_widget(form.nom) }}
							</div>
							{{ form_errors(form.nom) }}
						</div>

						<!-- Prénom -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-user-tag text-accent text-sm"></i>
								</span>
								{{ form_widget(form.lastname) }}
							</div>
							{{ form_errors(form.lastname) }}
						</div>


						<!-- Email -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-envelope text-accent text-sm"></i>
								</span>
								{{ form_widget(form.email) }}
							</div>
							{{ form_errors(form.email) }}
						</div>

						<!-- Téléphone -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-phone text-accent text-sm"></i>
								</span>
								{{ form_widget(form.tele) }}
							</div>
							{{ form_errors(form.tele) }}
						</div>

						<!-- Consent -->
						<div class="bg-white rounded-lg border border-blue-200 p-1.5 mt-2">
							<span class="text-xs text-gray-600 leading-tight block text-justify">
								En cliquant sur "Comparer", vous acceptez de transmettre vos informations à AKSAM ASSURANCES, qui accepte de les utiliser conformément à sa politique de confidentialité dans le but de vous fournir des propositions de devis d'assurance adaptées à votre recherche.
							</span>
						</div>

						<!-- Bouton -->
						<button type="submit" class="w-full bg-accent text-white font-bold py-3 px-4 rounded-lg text-sm lg:text-base pulse-animation shadow-lg hover:shadow-2xl transition-all duration-300 mt-3">
							<i class="fas fa-calculator mr-2"></i>
							Comparer 
						</button>

						{{ form_end(form) }}

					</div>
				</div>


			</div>
		</div>
	</section>

	<!-- Why Section -->
	<section class="py-8 lg:py-20 bg-surface">
		<div class="container mx-auto px-4 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-8 lg:mb-16">
					<h2 class="text-2xl lg:text-5xl font-bold text-gradient mb-4 lg:mb-6 leading-tight">
						Pourquoi une assurance spécifique pour votre utilitaire est indispensable ?
					</h2>
					{# <div class="w-16 lg:w-24 h-1 bg-gradient-to-r from-blue-400 to-blue-500 mx-auto rounded-full"></div> #}
					<p class="text-gray-600 mt-4 max-w-3xl mx-auto">
						Un contrat auto personnel ne suffit pas. L'usage intensif, le matériel de valeur transporté et les risques spécifiques à votre métier exigent des garanties dédiées.
					</p>
				</div>

				<div
					class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-8">

					<!-- Card 1 : Couverture usage pro -->
					<div
						class="bg-surface rounded-xl p-4 lg:p-8 shadow-xl border border-gray-100 card-hover">
						<!-- Icône + Titre sur la même ligne -->
						<div class="flex items-center gap-3 lg:gap-4 mb-4">
							<div class="p-2.5 lg:p-3 bg-gradient-to-br from-blue-400 to-blue-500 rounded-xl shadow-lg flex-shrink-0">
								<i class="fas fa-briefcase text-white text-lg lg:text-2xl"></i>
							</div>
							<h3 class="text-base lg:text-xl font-bold text-gradient">Couverture usage pro</h3>
						</div>
						<!-- Texte en dessous -->
						<p class="text-gray-700 text-sm lg:text-base">
							Tournée, livraisons, interventions sur chantier... Votre usage est totalement couvert.
						</p>
					</div>

					<!-- Card 2 : Valeur matériel prise en compte -->
					<div
						class="bg-surface rounded-xl p-4 lg:p-8 shadow-xl border border-gray-100 card-hover">
						<!-- Icône + Titre sur la même ligne -->
						<div class="flex items-center gap-3 lg:gap-4 mb-4">
							<div class="p-2.5 lg:p-3 bg-gradient-to-br from-blue-400 to-blue-500 rounded-xl shadow-lg flex-shrink-0">
								<i class="fas fa-tools text-white text-lg lg:text-2xl"></i>
							</div>
							<h3 class="text-base lg:text-xl font-bold text-gradient">Valeur matériel prise en compte</h3>
						</div>
						<!-- Texte en dessous -->
						<p class="text-gray-700 text-sm lg:text-base">
							Vos outils et marchandises sont votre gagne-pain. Assurez-les à leur juste valeur.
						</p>
					</div>

					<!-- Card 3 : Protection des aménagements -->
					<div
						class="bg-surface rounded-xl p-4 lg:p-8 shadow-xl border border-gray-100 card-hover">
						<!-- Icône + Titre sur la même ligne -->
						<div class="flex items-center gap-3 lg:gap-4 mb-4">
							<div class="p-2.5 lg:p-3 bg-gradient-to-br from-blue-400 to-blue-500 rounded-xl shadow-lg flex-shrink-0">
								<i class="fas fa-box-open text-white text-lg lg:text-2xl"></i>
							</div>
							<h3 class="text-base lg:text-xl font-bold text-gradient">Protection des aménagements</h3>
						</div>
						<!-- Texte en dessous -->
						<p class="text-gray-700 text-sm lg:text-base">
							Vos étagères, galerie de toit ou caisse frigorifique sont également couverts.
						</p>
					</div>

				</div>
			</div>
		</div>
	</section>


	<!-- Guarantees Section -->
	<section class="py-8 lg:py-20 bg-light">
		<div class="container mx-auto px-4 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-8 lg:mb-16">
					<h2 class="text-2xl lg:text-5xl font-bold text-gradient mb-4 lg:mb-6">Des Garanties sur mesure pour votre activité</h2>
					{# <div class="w-16 lg:w-24 h-1 bg-gradient-to-r from-blue-400 to-blue-500 mx-auto rounded-full"></div> #}
					<p class="text-gray-600 mt-4 max-w-3xl mx-auto">Ne payez que pour les garanties qui vous sont vraiment utiles</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-box text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Garantie Contenu Professionnel</h3>
						</div>
						<p class="text-gray-600 text-sm">LA garantie essentielle. Indemnisation en cas de vol ou de détérioration de votre outillage, équipements et marchandises.</p>
					</div>

					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-life-ring text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Assistance 0 km + Véhicule de Remplacement</h3>
						</div>
						<p class="text-gray-600 text-sm">Dépannage sur place et véhicule de remplacement de même catégorie pour ne jamais arrêter votre activité.</p>
					</div>

					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-glass-martini text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Bris de Glace étendu</h3>
						</div>
						<p class="text-gray-600 text-sm">Inclut les optiques de phares et les rétroviseurs, souvent plus exposés sur les utilitaires.</p>
					</div>

					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-shield-alt text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Dommages Tous Accidents & Vandalisme</h3>
						</div>
						<p class="text-gray-600 text-sm">La tranquillité d'esprit absolue, même en cas d'accident responsable ou de dégradation.</p>
					</div>

					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-gavel text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Protection Juridique Professionnelle</h3>
						</div>
						<p class="text-gray-600 text-sm">Un soutien d'experts pour vous défendre en cas de litige suite à un accident de la route.</p>
					</div>

					<div class="bg-surface rounded-xl p-4 lg:p-6 shadow-lg card-hover border-l-4 border-blue-400">
						<div class="flex items-start gap-3 mb-3">
							<i class="fas fa-wrench text-blue-500 text-2xl mt-1"></i>
							<h3 class="font-bold text-dark text-lg">Aménagements spécifiques</h3>
						</div>
						<p class="text-gray-600 text-sm">Protection de vos étagères, galerie, caisse frigorifique et autres équipements pro.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-8 lg:py-20 bg-surface">
		<div class="container mx-auto px-4 lg:px-8">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-8 lg:mb-12">
					<h2 class="text-2xl lg:text-4xl font-bold text-gradient mb-4">Questions Fréquentes</h2>
					{# <div class="w-16 h-1 bg-gradient-to-r from-blue-400 to-blue-500 mx-auto rounded-full"></div> #}
				</div>

				<div class="space-y-4">
					<div class="bg-light rounded-xl overflow-hidden shadow-md">
						<div class="faq-question p-4 cursor-pointer flex justify-between items-center hover:bg-gray-100 transition">
							<span class="font-semibold text-dark">Mon outillage est-il automatiquement couvert en cas de vol dans mon fourgon ?</span>
							<span class="faq-toggle text-2xl text-accent">+</span>
						</div>
						<div class="faq-answer px-4 pb-4 text-gray-600 hidden">
							Non, la couverture de base ne protège pas le contenu. Pour assurer votre matériel, outils et marchandises contre le vol ou la casse, il est indispensable de souscrire l'option "Garantie du Contenu Professionnel". C'est l'option la plus importante pour un artisan.
						</div>
					</div>

					<div class="bg-light rounded-xl overflow-hidden shadow-md">
						<div class="faq-question p-4 cursor-pointer flex justify-between items-center hover:bg-gray-100 transition">
							<span class="font-semibold text-dark">Que se passe-t-il si mon utilitaire tombe en panne sur un chantier ?</span>
							<span class="faq-toggle text-2xl text-accent">+</span>
						</div>
						<div class="faq-answer px-4 pb-4 text-gray-600 hidden">
							Avec notre Assistance 0 km, peu importe où vous vous trouvez, nous organisons le dépannage. Selon votre contrat, nous mettons à disposition un véhicule utilitaire de remplacement pour poursuivre votre activité sans interruption.
						</div>
					</div>

					<div class="bg-light rounded-xl overflow-hidden shadow-md">
						<div class="faq-question p-4 cursor-pointer flex justify-between items-center hover:bg-gray-100 transition">
							<span class="font-semibold text-dark">Puis-je utiliser mon assurance auto personnelle pour mon usage professionnel ?</span>
							<span class="faq-toggle text-2xl text-accent">+</span>
						</div>
						<div class="faq-answer px-4 pb-4 text-gray-600 hidden">
							C'est fortement déconseillé et risqué. Un contrat personnel ne couvre généralement pas les déplacements professionnels. En cas d'accident durant votre activité, votre assureur pourrait refuser toute indemnisation. Seule une assurance utilitaire professionnel vous garantit d'être couvert.
						</div>
					</div>

					<div class="bg-light rounded-xl overflow-hidden shadow-md">
						<div class="faq-question p-4 cursor-pointer flex justify-between items-center hover:bg-gray-100 transition">
							<span class="font-semibold text-dark">Les aménagements spécifiques sont-ils assurés ?</span>
							<span class="faq-toggle text-2xl text-accent">+</span>
						</div>
						<div class="faq-answer px-4 pb-4 text-gray-600 hidden">
							Oui, nos contrats pros peuvent inclure une garantie des aménagements professionnels. Il est important de déclarer la valeur de ces équipements pour qu'ils soient correctement couverts en cas de sinistre.
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Final -->
	<section class="py-8 lg:py-20 bg-gradient-to-r from-blue-200 to-blue-400">
		<div class="container mx-auto px-4 text-center">
			<div class="max-w-3xl mx-auto">
				<div class="w-10 h-10 lg:w-16 lg:h-16 bg-white/20 rounded-xl mx-auto mb-4 lg:mb-6 flex items-center justify-center">
					<i class="fas fa-calculator text-lg lg:text-3xl text-white"></i>
				</div>
				<h2 class="text-xl lg:text-4xl font-bold mb-4 lg:mb-6 text-white">Protégez Votre Utilitaire Professionnel</h2>
				<p class="text-sm lg:text-xl mb-6 lg:mb-8 text-white/90 leading-relaxed">
					Obtenez en quelques clics un tarif personnalisé qui correspond précisément à vos besoins, sans superflu.
				</p>
				<a href="#contactForm" class="inline-block bg-accent text-white font-bold py-3 lg:py-4 px-6 lg:px-10 rounded-lg hover:bg-orange-600 transition-all transform hover:scale-105 shadow-2xl text-sm lg:text-base">
					<i class="fas fa-arrow-up mr-2"></i>
					Calculer mon Tarif Utilitaire
				</a>
			</div>
		</div>
	</section>


	<script>
		// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
anchor.addEventListener('click', function (e) {
e.preventDefault();
const target = document.querySelector(this.getAttribute('href'));
if (target) {
target.scrollIntoView({behavior: 'smooth', block: 'start'});
}
});
});
	</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Mon outillage est-il automatiquement couvert en cas de vol dans mon fourgon ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, la couverture de base ne protège pas le contenu. Pour assurer votre matériel, outils et marchandises contre le vol ou la casse, il est indispensable de souscrire l'option \"Garantie du Contenu Professionnel\"."
      }
    },
    {
      "@type": "Question",
      "name": "Que se passe-t-il si mon utilitaire tombe en panne sur un chantier ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avec notre Assistance 0 km, peu importe où vous vous trouvez, nous organisons le dépannage. Selon votre contrat, nous mettons à disposition un véhicule utilitaire de remplacement pour poursuivre votre activité sans interruption."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je utiliser mon assurance auto personnelle pour mon usage professionnel ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "C'est fortement déconseillé. Un contrat personnel ne couvre généralement pas les déplacements professionnels. En cas d'accident durant votre activité, votre assureur pourrait refuser toute indemnisation. Seule une assurance utilitaire professionnel vous garantit d'être couvert."
      }
    },
    {
      "@type": "Question",
      "name": "Les aménagements spécifiques de mon utilitaire sont-ils assurés ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, nos contrats pros peuvent inclure une garantie des aménagements professionnels. Il est important de déclarer la valeur de ces équipements pour qu'ils soient correctement couverts en cas de sinistre."
      }
    }
  ]
}
</script>

{% endblock %}
