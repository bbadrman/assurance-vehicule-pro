                        <div>
                            <h3 class="font-bold text-dark text-lg mb-2">Protection des Voyageurs</h3>
                            <p class="text-gray-600 text-sm">Couverture des préjudices corporels subis à bord par les passagers, avec des plafonds adaptés au transport collectif.</p>
                        </div>
                    </div>
                </div>

                <!-- Card 3 : Dommages Tous Accidents -->
                <div class="bg-light rounded-xl p-6 shadow-lg card-hover border-l-4 border-blue-400">
