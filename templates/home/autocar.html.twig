{% extends 'base.html.twig' %}

{% block title %}Assurance pour autocar : devis et tarifs en ligne{% endblock %}
{% block description %}<meta name="description" content="Trouvez la meilleure assurance pour autocar adaptée à votre activité. Comparez les garanties, obtenez un devis personnalisé et protégez votre flotte rapidement.">{% endblock %}
{% block canonical %}<link rel="canonical" href="https://assurance-vehicule-pro.fr/assurance-pour-autocar">{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="py-0 lg:py-2 bg-gradient-to-br from-light via-surfaceHover to-light relative overflow-hidden">
    <div class="hidden lg:flex absolute top-2 left-2 lg:top-5 lg:left-5 floating-animation">
        <i class="fas fa-bus text-blue-600 text-2xl lg:text-4xl opacity-30"></i>
    </div>
    <div class="hidden lg:flex absolute bottom-2 right-2 lg:bottom-5 lg:right-5 floating-animation" style="animation-delay: -2s;">
        <i class="fas fa-shuttle-van text-blue-700 text-3xl lg:text-5xl opacity-25"></i>
    </div>

    <div class="w-full mx-auto px-4 lg:px-40 relative z-10">
        <div class="flex flex-col lg:flex-row gap-2 lg:gap-3 items-stretch">
            
            <!-- Image Section -->
            <div class="order-2 lg:order-1 slide-in-left flex-1 lg:flex-[7]">
                <div class="relative h-full min-h-[150px] lg:min-h-[400px]">
<div class="w-full h-full bg-gradient-to-br from-blue-400 to-blue-500 shadow-2xl overflow-hidden rounded-xl lg:rounded-3xl">
                            <img src="{{ asset('public/images/poid-lourd.png') }}" alt="assurance autocar" class="w-full h-full rounded-xl lg:rounded-3xl shadow-2xl" loading="lazy" />
                        </div>
                </div>
            </div>

            <!-- Form Section -->
            <div class="order-1 lg:order-2 slide-in-right flex-1 lg:flex-[3]">
                <div class="bg-surface shadow-2xl p-3 lg:p-4 card-hover border-l border-gray-100 h-full rounded-xl lg:rounded-3xl">
                    <div class="text-center mb-2 lg:mb-3">
                        <div class="w-10 h-10 lg:w-12 lg:h-12 bg- rounded-xl mx-auto mb-2 flex items-center justify-center">
                             
                              <i class="fas fa-calculator text-lg lg:text-2xl text-accent"></i>
                        </div>
                        <h2 class="text-sm lg:text-xl font-bold text-gradient mb-2 leading-tight">Complétez ce formulaire pour obtenir un devis autocar</h2>
                    </div>
  
				{{ form_start(form, {'attr': {'id': 'contactForm', 'class': 'space-y-2 lg:space-y-3'}}) }}

			
				<!-- Raison sociale -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-building text-accent text-sm"></i>
						</span>
						{{ form_widget(form.raison) }}
					</div>
					{{ form_errors(form.raison) }}
				</div>
                     
                    <!-- Demarage d'activité -->
                <div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-briefcase text-accentchamp text-sm"></i>
						</span>
						<select id="transport_type" name="type" required="required" class="flex-1 px-3 py-2 border border-gray-200 rounded-r-lg bg-light focus:bg-surface transition-all duration-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" style="appearance: auto; -webkit-appearance: menulist;">
						<option value="" selected="selected">Demarage d'activité </option>
						<option value="">OUI</option>
						<option value="">NON</option>
						</select>
					</div>
					
				</div>
				<!-- Activité -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-briefcase text-accent text-sm"></i>
						</span>
						{{ form_widget(form.activite) }}
					</div>
					{{ form_errors(form.activite) }}
				</div>

				<!-- Véhicule assuré -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-shield-alt text-accent text-sm"></i>
						</span>
						{{ form_widget(form.assurer) }}
					</div>
					{{ form_errors(form.assurer) }}
				</div>

				<!-- Code Postal -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-map-marker-alt text-accent text-sm"></i>
						</span>
						{{ form_widget(form.codePostale) }}
					</div>
					{{ form_errors(form.codePostale) }}
				</div>
                    <!-- Nom -->
                    <div class="form-group">
						<div class="flex">
							<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
								<i class="fas fa-user text-accent text-sm"></i>
							</span>
							{{ form_widget(form.nom) }}
						</div>
						{{ form_errors(form.nom) }}
					</div>

				<!-- Prénom -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-user-tag text-accent text-sm"></i>
						</span>
						{{ form_widget(form.lastname) }}
					</div>
					{{ form_errors(form.lastname) }}
				</div>


				<!-- Email -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-envelope text-accent text-sm"></i>
						</span>
						{{ form_widget(form.email) }}
					</div>
					{{ form_errors(form.email) }}
				</div>

				<!-- Téléphone -->
				<div class="form-group">
					<div class="flex">
						<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
							<i class="fas fa-phone text-accent text-sm"></i>
						</span>
						{{ form_widget(form.tele) }}
					</div>
					{{ form_errors(form.tele) }}
				</div>

				<!-- Consent -->
				<div class="bg-white rounded-lg border border-blue-200 p-1.5 mt-2">
					<span class="text-xs text-gray-600 leading-tight block text-justify">
						En cliquant sur "Comparer", vous acceptez de transmettre vos informations à AKSAM ASSURANCES, qui accepte de les utiliser conformément à sa politique de confidentialité dans le but de vous fournir des propositions de devis d'assurance adaptées à votre recherche.
					</span>
				</div>

				<!-- Bouton -->
				<button type="submit" class="w-full bg-accent text-white font-bold py-3 px-4 rounded-lg text-sm lg:text-base pulse-animation shadow-lg hover:shadow-2xl transition-all duration-300 mt-3">
					<i class="fas fa-calculator mr-2"></i>
					Comparer 
				</button>

				{{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
</section>

<!-- Intro Section -->
<section class="py-8 lg:py-16 bg-surface">
    <div class="container mx-auto px-4 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-3xl lg:text-5xl font-bold text-gradient mb-6">Assurance pour autocar</h1>
            <h2 class="text-2xl lg:text-4xl font-bold text-gradient mb-6">L'assurance adaptée aux professionnels du transport collectif</h2>
            <p class="text-gray-700 text-base lg:text-lg leading-relaxed">
                Transporter des passagers à bord d'un autocar engage une responsabilité considérable. Qu'il s'agisse de lignes régulières, de circuits touristiques ou de transport scolaire, chaque trajet implique une couverture d'assurance à la hauteur des risques réels. En France, l'obligation légale est stricte, les sinistres coûtent cher, et les compagnies d'assurance évaluent ces contrats avec des critères bien précis.
            </p>
            <p class="text-accent font-semibold mt-4 text-lg">
                Nos experts accompagnent les professionnels du transport collectif pour trouver le contrat le plus adapté à leur activité, à leur flotte et à leur budget.
            </p>
        </div>
    </div>
</section>

