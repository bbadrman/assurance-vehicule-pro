<!-- Guarantees Section -->
<section class="py-8 lg:py-20 bg-surface">
    <div class="container mx-auto px-4 lg:px-8">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-8 lg:mb-16">
                <h2 class="text-2xl lg:text-5xl font-bold text-gradient mb-4 lg:mb-6">Des Garanties Essentielles pour le transport collectif</h2>
                <p class="text-gray-600 mt-4">La protection légale minimale et les garanties complémentaires indispensables</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Card 1 : Responsabilité Civile -->
                <div class="bg-light rounded-xl p-6 shadow-lg card-hover border-l-4 border-blue-400">
                    <div class="flex items-start gap-4 mb-3">
                        <i class="fas fa-shield-alt text-blue-500 text-3xl mt-1"></i>
                        <div>
                            <h3 class="font-bold text-dark text-lg mb-2">Responsabilité Civile Transport de Voyageurs</h3>
                            <p class="text-gray-600 text-sm">La base légale obligatoire imposée par l'article L. 3112-1 du Code des transports. Elle couvre les dommages corporels et matériels causés aux passagers et aux tiers.</p>
                        </div>
                    </div>
                </div>

                <!-- Card 2 : Protection des Voyageurs -->
                <div class="bg-light rounded-xl p-6 shadow-lg card-hover border-l-4 border-blue-400">
                    <div class="flex items-start gap-4 mb-3">
