{% endblock %} 
         {% block description %}<meta name="description" content="Protégez votre poids lourds pro, quelle que soit votre activité. Assurance sur-mesure pour transporteurs, BTP, logistique. Devis en ligne : RC Pro, marchandises, assistance 0km.">
		{% endblock %}
