								</span>
								{{ form_widget(form.lastname) }}
							</div>
							{{ form_errors(form.lastname) }}
						</div>


						<!-- Email -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-envelope text-accent text-sm"></i>
								</span>
								{{ form_widget(form.email) }}
							</div>
							{{ form_errors(form.email) }}
						</div>

						<!-- Téléphone -->
						<div class="form-group">
							<div class="flex">
								<span class="inline-flex items-center px-2 py-4 bg-gray-50 border border-r-0 border-gray-200 rounded-l-lg text-gray-600">
									<i class="fas fa-phone text-accent text-sm"></i>
								</span>
								{{ form_widget(form.tele) }}
							</div>
							{{ form_errors(form.tele) }}
						</div>

						<!-- Consent -->
						<div class="bg-white rounded-lg border border-blue-200 p-1.5 mt-2">
							<span class="text-xs text-gray-600 leading-tight block text-justify">
								En cliquant sur "Comparer", vous acceptez de transmettre vos informations à AKSAM ASSURANCES, qui accepte de les utiliser conformément à sa politique de confidentialité dans le but de vous fournir des propositions de devis d'assurance adaptées à votre recherche.
							</span>
						</div>

						<!-- Bouton -->
						<button type="submit" class="w-full bg-accent text-white font-bold py-3 px-4 rounded-lg text-sm lg:text-base pulse-animation shadow-lg hover:shadow-2xl transition-all duration-300 mt-3">
							<i class="fas fa-calculator mr-2"></i>
							Comparer 
						</button>

						{{ form_end(form) }}

                    </div>
                </div>
            </div>
